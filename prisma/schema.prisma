datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  KAKAO
  NAVER
}

enum CreationMode {
  period
  weekly
  multiple
  single
}

enum ScheduleType {
  task
  event
}

model User {
  id              String           @id @default(uuid())
  email           String           
  name            String?
  provider        AuthProvider     @default(LOCAL)
  providerId      String?
  
  schedules       Schedule[]
  goals           Goal[]
  milestones      Milestone[]
  categories      Category[]
  priorityOptions PriorityOption[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([email, provider])
}

model Schedule {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  groupId         String?       
  creationMode    CreationMode    @default(single)
  type            ScheduleType    @default(task)
  
  goalId          String?
  goal            Goal?           @relation(fields: [goalId], references: [id], onDelete: SetNull)
  milestoneId     String?
  milestone       Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priorityId      String?
  priority        PriorityOption? @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  
  summary         String
  done            Boolean         @default(false)
  startDate       DateTime        @db.Date
  endDate         DateTime?       @db.Date
  startTime       String?
  endTime         String?
  
  isPinned        Boolean         @default(false)
  orderIndex      Int             @default(0)
  isRecurring     Boolean         @default(false)
  repeatWeekdays  String[]       
  
  subtasks        Json?           

  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // ✅ Pull 동기화 성능 최적화용 인덱스
  @@index([userId, updatedAt])
}

model Goal {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  startDate       DateTime        @db.Date
  endDate         DateTime?       @db.Date
  color           String          @default("#ef4444")
  isArchived      Boolean         @default(false)
  
  milestones      Milestone[]
  schedules       Schedule[]


  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, updatedAt])
}

model Milestone {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId          String
  goal            Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title           String
  startDate       DateTime        @db.Date
  endDate         DateTime?       @db.Date
  done            Boolean         @default(false)
  
  schedules       Schedule[]


  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, updatedAt])
}

model Category {
  id              String          @id 
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String
  emoji           String

  schedules       Schedule[] 

  deletedAt       DateTime?
  updatedAt       DateTime        @updatedAt

  @@index([userId, updatedAt])
}

model PriorityOption {
  id              String          @id 
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String
  emoji           String
  color           String

  schedules       Schedule[] 

  deletedAt       DateTime?
  updatedAt       DateTime        @updatedAt

  @@index([userId, updatedAt])
}
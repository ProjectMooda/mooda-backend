datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  KAKAO
  NAVER
}

enum CreationMode {
  period
  weekly
  multiple
  single
}

enum ScheduleType {
  task
  event
}

// =========================================
// 사용자 정보
// =========================================
model User {
  id              String           @id @default(uuid())
  email           String           
  name            String?
  provider        AuthProvider     @default(LOCAL)
  providerId      String?
  
  schedules       Schedule[]
  goals           Goal[]
  milestones      Milestone[]
  categories      Category[]
  priorityOptions PriorityOption[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([email, provider])
}

// =========================================
// 일정 관리 모델 (동기화 대상)
// =========================================
model Schedule {
  id              String         @id @default(uuid()) // 프론트의 UUID를 수용
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  groupId         String?       
  creationMode    CreationMode   @default(single)
  type            ScheduleType   @default(task)
  
  goalId          String?
  goal            Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
  milestoneId     String?
  milestone       Milestone?     @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  
  // ✅ 관계 설정 추가 및 onDelete: SetNull 적용
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priorityId      String?
  priority        PriorityOption? @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  
  summary         String
  done            Boolean        @default(false)
  startDate       DateTime       @db.Date
  endDate         DateTime?      @db.Date
  startTime       String?
  endTime         String?
  
  isPinned        Boolean        @default(false)
  orderIndex      Int            @default(0)
  isRecurring     Boolean        @default(false)
  repeatWeekdays  String[]       
  
  // ✅ JSON 타입으로 변경 권장 (프론트엔드와 1:1 매칭, 동기화 로직 극강의 단순화)
  subtasks        Json?          // 예: [{ "id": "...", "text": "...", "done": false }]
  
  // ✅ 오프라인 동기화 핵심 필드 추가
  clientUpdatedAt DateTime       
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Goal {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  startDate       DateTime    @db.Date
  endDate         DateTime?   @db.Date
  color           String      @default("#ef4444")
  isArchived      Boolean     @default(false)
  
  milestones      Milestone[]
  schedules       Schedule[]

  // ✅ 오프라인 동기화 핵심 필드
  clientUpdatedAt DateTime    
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Milestone {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId          String
  goal            Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title           String
  startDate       DateTime    @db.Date
  endDate         DateTime?   @db.Date
  done            Boolean     @default(false)
  
  schedules       Schedule[]

  // ✅ 오프라인 동기화 핵심 필드
  clientUpdatedAt DateTime    
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Category {
  id              String     @id 
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String
  emoji           String

  schedules       Schedule[] // ✅ 관계의 반대편(역방향) 설정 추가

  // ✅ 오프라인 동기화 핵심 필드
  clientUpdatedAt DateTime    
}

model PriorityOption {
  id              String     @id 
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String
  emoji           String
  color           String

  schedules       Schedule[] // ✅ 관계의 반대편(역방향) 설정 추가

  // ✅ 오프라인 동기화 핵심 필드
  clientUpdatedAt DateTime    
}